<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Bootstrap demo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>

  <div class="container">
    <div class="text-center mt-3">Bento Grid Layout</div>
    <div class="row">
      <div class="col-8">
        <div class="bg-primary text-center text-white rounded-3 align-content-center" style="height: 250px;">
          <div>Large Item</div>
        </div>
      </div>
      <div class="col-4">
        <div class="row">
          <div class="col-12">
            <div class="bg-success text-white text-center rounded-3 align-content-center mt-3" style="height:120px;">
              <div>Small Item 1</div>
            </div>
          </div>
          <div class="col-12">
            <div class="bg-danger text-white text-center rounded-3 align-content-center mt-3" style="height:120px;">
              <div>Smal item 2</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-4">
        <div class="bg-warning text-white text-center rounded-3 align-content-center mt-3" style="height:120px;">
          <div>Medium item 1</div>
        </div>
      </div>

      <div class="col-4">
        <div class="bg-info text-white text-center rounded-3 align-content-center mt-3" style="height:120px;">
          <div>Medium item 2</div>
        </div>
      </div>

      <div class="col-4">
        <div class="bg-secondary text-white text-center rounded-3 align-content-center mt-3" style="height:120px;">
          <div>Medium item 3</div>
        </div>
      </div>
    </div>
  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
